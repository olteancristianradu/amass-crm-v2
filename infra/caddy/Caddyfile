# Dev Caddyfile — reverse proxy for local development.
# Prod Caddyfile (with auto-HTTPS) lives in infra/caddy/Caddyfile.prod.

{
	auto_https off
	admin off
}

:80 {
	# API under /api
	handle /api/* {
		reverse_proxy api:3000
	}

	# Socket.IO upgrade traffic — useReminderPoller + NotificationsBell
	# connect via `io({ path: '/ws' })`. Caddy upgrades WS connections
	# automatically when the matching upstream returns 101; without this
	# handle, every connect spam-fails with "bad response from server".
	handle /ws* {
		reverse_proxy api:3000
	}

	# AI worker under /ai
	handle /ai/* {
		uri strip_prefix /ai
		reverse_proxy ai-worker:8000
	}

	# Everything else → frontend
	# web container runs nginx-unprivileged on 8080 (apps/web/Dockerfile),
	# not 80 — hitting :80 here used to 502 on every non-/api request.
	handle {
		reverse_proxy web:8080
	}
}
