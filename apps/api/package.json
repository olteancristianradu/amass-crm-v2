{
  "name": "@amass/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push --skip-generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@amass/shared": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^6.0.0",
    "@types/express": "^5.0.6",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.21.2",
    "express": "^5.2.1",
    "ioredis": "^5.4.1",
    "minio": "^8.0.2",
    "multer": "^2.1.1",
    "nestjs-pino": "^4.1.0",
    "nodemailer": "^8.0.5",
    "papaparse": "^5.5.3",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "twilio": "^5.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.4",
    "@swc/core": "^1.15.24",
    "@types/bcrypt": "^5.0.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.5",
    "@types/nodemailer": "^8.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/supertest": "^6.0.2",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^6.0.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.1.2"
  }
}
