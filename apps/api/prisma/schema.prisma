// ─── Validation Rules (custom field validation on entities) ───────────────────

enum ValidationEntityType {
  COMPANY
  CONTACT
  CLIENT
  DEAL
  LEAD
  CASE
  ORDER
}

enum ValidationOperator {
  REGEX
  MIN_LENGTH
  MAX_LENGTH
  EQUALS
  NOT_EQUALS
}

/**
 * Business rules applied pre-save on entity writes. Minimal expression engine:
 * a single `field` + operator + value. Complex boolean logic is intentionally
 * deferred — if you need AND/OR, create multiple rules.
 */
model ValidationRule {
  id           String               @id @default(cuid())
  tenantId     String               @map("tenant_id")
  entityType   ValidationEntityType @map("entity_type")
  field        String
  operator     ValidationOperator
  value        String
  errorMessage String               @map("error_message")
  isActive     Boolean              @default(true) @map("is_active")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  @@index([tenantId, entityType, isActive])
  @@map("validation_rules")
}

// ─── Formula Fields ───────────────────────────────────────────────────────────

/**
 * Tenant-defined computed fields. Expression references other fields by name.
 * Evaluation is deliberately sandboxed — no free-form JS. Operators: + - * /,
 * CONCAT(...), IF(cond, a, b). See FormulaEvaluator for exact grammar.
 */
model FormulaField {
  id         String               @id @default(cuid())
  tenantId   String               @map("tenant_id")
  entityType ValidationEntityType @map("entity_type")
  fieldName  String               @map("field_name")
  expression String
  returnType String               @default("STRING") @map("return_type")
  isActive   Boolean              @default(true) @map("is_active")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")

  @@unique([tenantId, entityType, fieldName])
  @@map("formula_fields")
}

