// AMASS-CRM v2 — Prisma schema
// Sprint 1: Tenant, User, Session (auth foundation)
// RLS policies + audit + RBAC arrive in Sprint 2.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), pg_trgm]
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
  VIEWER
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // G-prep: stable shard key precomputed once so the app can be migrated to a
  // sharded Postgres (Citus/Vitess) without rewriting every query. Until the
  // sharding threshold is crossed (see CLAUDE.md), this is purely advisory.
  shardId            Int?
  // E-compliance: SIEM webhook for audit log forwarding. NULL = use global
  // SIEM_WEBHOOK_URL fallback. Only populated for tenants with own collector.
  siemWebhookUrl     String?
  // E-compliance: tenant-specific retention override (days). NULL = use
  // AUDIT_RETENTION_DAYS_DEFAULT.
  auditRetentionDays Int?

  users User[]

  @@index([shardId])
  @@map("tenants")
}

model User {
  id              String    @id @default(cuid())
  tenantId        String
  email           String
  emailVerifiedAt DateTime? @map("email_verified_at")
  passwordHash    String
  fullName        String
  role            UserRole  @default(AGENT)
  isActive        Boolean   @default(true)
  // TOTP two-factor authentication. Secret is stored encrypted via ENCRYPTION_KEY.
  // totpEnabled gates the TOTP check in the login flow.
  totpSecret      String?   @map("totp_secret")
  totpEnabled     Boolean   @default(false) @map("totp_enabled")
  // Hashed TOTP backup codes — JSON array of SHA-256 hex digests. Each
  // code is single-use: on successful TOTP backup-login we splice it
  // out of the array. Raw codes are shown to the user ONCE at enrol time.
  totpBackupCodes Json?     @map("totp_backup_codes")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions                Session[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  // Email is unique within a tenant, not globally — multi-tenant requirement.
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

/**
 * Password reset tokens — one-time bearer tokens mailed to the user.
 * Token is stored as SHA-256 hash so a DB dump does not let an attacker
 * reset anyone's password. `used=true` is set on successful consumption
 * and never un-set. Row TTL is via `expiresAt`; a cron prunes expired.
 */
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  ipAddress String?   @map("ip_address")
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

/**
 * Email verification tokens. Issued at register() and on email change.
 * Same hash + TTL + single-use semantics as password reset.
 */
model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

enum ImportType {
  CLIENTS
  COMPANIES
  CONTACTS
}

enum ImportStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model ImportJob {
  id          String       @id @default(cuid())
  tenantId    String
  type        ImportType
  status      ImportStatus @default(PENDING)
  fileName    String
  storageKey  String // MinIO object key — `<tenantId>/imports/<uuid>-<fileName>`
  totalRows   Int          @default(0)
  processed   Int          @default(0)
  succeeded   Int          @default(0)
  failed      Int          @default(0)
  skipped     Int          @default(0)
  errors      Json? // array of {row, message}
  createdById String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@map("import_jobs")
}

enum CompanySize {
  MICRO // 1-9
  SMALL // 10-49
  MEDIUM // 50-249
  LARGE // 250+
}

/// CRM relationship lifecycle stage for a company.
enum RelationshipStatus {
  LEAD
  PROSPECT
  ACTIVE
  INACTIVE
}

/// How this company/lead was acquired.
enum LeadSource {
  REFERRAL
  WEB
  COLD_CALL
  EVENT
  PARTNER
  SOCIAL
  OTHER
}

model Company {
  id                 String                       @id @default(cuid())
  tenantId           String
  name               String
  vatNumber          String? // CUI for Romanian companies
  registrationNumber String? // J-number
  industry           String?
  size               CompanySize?
  relationshipStatus RelationshipStatus?          @map("relationship_status")
  leadSource         LeadSource?                  @map("lead_source")
  website            String?
  email              String?
  phone              String?
  addressLine        String?
  city               String?
  county             String?
  postalCode         String?
  country            String?                      @default("RO")
  notes              String?
  createdById        String?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  deletedAt          DateTime?
  /// Populated asynchronously by EmbeddingService (OpenAI text-embedding-3-small).
  /// Not accessible via normal Prisma client — use $queryRaw for vector ops.
  embedding          Unsupported("vector(1536)")?
  parentId           String?                      @map("parent_id")
  // When a parent company is deleted, subsidiaries become root-level (no cascade) —
  // safer than cascading since we also don't want to lose their data.
  parent             Company?                     @relation("CompanyHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  subsidiaries       Company[]                    @relation("CompanyHierarchy")

  contacts Contact[]
  quotes   Quote[]

  @@index([tenantId, createdAt])
  @@index([tenantId, name])
  @@index([tenantId, vatNumber])
  @@index([tenantId, relationshipStatus])
  @@index([parentId])
  @@map("companies")
}

model Contact {
  id          String                       @id @default(cuid())
  tenantId    String
  companyId   String?
  firstName   String
  lastName    String
  jobTitle    String?
  email       String?
  phone       String?
  mobile      String?
  isDecider   Boolean                      @default(false) @map("is_decider")
  notes       String?
  createdById String?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt
  deletedAt   DateTime?
  /// See Company.embedding note above.
  embedding   Unsupported("vector(1536)")?

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, companyId])
  @@index([tenantId, lastName, firstName])
  @@map("contacts")
}

model Client {
  id          String                       @id @default(cuid())
  tenantId    String
  firstName   String
  lastName    String
  email       String?
  phone       String?
  mobile      String?
  addressLine String?
  city        String?
  county      String?
  postalCode  String?
  country     String?                      @default("RO")
  notes       String?
  createdById String?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt
  deletedAt   DateTime?
  /// See Company.embedding note above.
  embedding   Unsupported("vector(1536)")?

  @@index([tenantId, createdAt])
  @@index([tenantId, lastName, firstName])
  @@index([tenantId, email])
  @@map("clients")
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorId     String?
  action      String // e.g. "user.create", "auth.login", "company.delete"
  subjectType String? // e.g. "user", "company"
  subjectId   String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@index([tenantId, subjectType, subjectId])
  @@map("audit_logs")
}

/// Polymorphic subject types — every notes/activities/attachments row
/// references one of these via (subjectType, subjectId). Keep in sync with
/// SubjectTypeSchema in @amass/shared.
enum SubjectType {
  COMPANY
  CONTACT
  CLIENT
}

model Attachment {
  id           String      @id @default(cuid())
  tenantId     String
  subjectType  SubjectType
  subjectId    String
  storageKey   String      @unique // path inside the MinIO bucket
  fileName     String
  mimeType     String
  size         Int
  uploadedById String?
  createdAt    DateTime    @default(now())
  deletedAt    DateTime?

  // Versioning — parentId points to the root (v1). version starts at 1
  // and increments for each new version. isLatest is denormalised for
  // cheap filtering in the list endpoint.
  parentId String?      @map("parent_id")
  version  Int          @default(1)
  isLatest Boolean      @default(true) @map("is_latest")
  // When the v1 parent is deleted, its versions also go — keeps file metadata
  // consistent with MinIO cleanup downstream.
  parent   Attachment?  @relation("AttachmentVersions", fields: [parentId], references: [id], onDelete: Cascade)
  versions Attachment[] @relation("AttachmentVersions")

  @@index([tenantId, subjectType, subjectId, createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, parentId])
  @@map("attachments")
}

model Note {
  id          String      @id @default(cuid())
  tenantId    String
  subjectType SubjectType
  subjectId   String
  /// Cap notes at 10_000 chars. Anything longer belongs in an attachment.
  body        String      @db.VarChar(10000)
  authorId    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  @@index([tenantId, subjectType, subjectId, createdAt])
  @@index([tenantId, createdAt])
  @@map("notes")
}

/// Polymorphic reminder. Created by a user, attached to any subject
/// (Company / Contact / Client today). A BullMQ delayed job is enqueued
/// at create time with `jobId = reminder.id` for idempotency. When the
/// delayed job fires, the processor flips status to FIRED and writes an
/// activity row. Snooze = cancel old job + re-enqueue at the new time;
/// dismiss/delete = cancel job. The job and the row are kept in sync via
/// the row id == BullMQ jobId convention.
enum ReminderStatus {
  PENDING
  FIRED
  DISMISSED
  CANCELLED
}

model Reminder {
  id          String         @id @default(cuid())
  tenantId    String
  subjectType SubjectType
  subjectId   String
  actorId     String? // who created the reminder (null if system)
  title       String
  body        String?
  remindAt    DateTime
  status      ReminderStatus @default(PENDING)
  firedAt     DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  @@index([tenantId, subjectType, subjectId, remindAt])
  @@index([tenantId, actorId, status, remindAt])
  @@index([tenantId, status, remindAt])
  @@map("reminders")
}

/// Domain-level activity log (NOT the audit_logs table). Activities are
/// what shows up in the UI timeline: "Andrei created this company",
/// "Maria added a note", "Status changed to WON". Audit_logs are
/// security-level and stay separate.
model Activity {
  id          String      @id @default(cuid())
  tenantId    String
  subjectType SubjectType
  subjectId   String
  actorId     String?
  action      String // e.g. "company.created", "note.added", "company.updated"
  metadata    Json?
  createdAt   DateTime    @default(now())

  @@index([tenantId, subjectType, subjectId, createdAt])
  @@index([tenantId, createdAt])
  @@map("activities")
}

/// Sprint 10 — Pipelines, Deals, Tasks.
///
/// Pipelines define the sales funnel. Each tenant can have multiple
/// pipelines (e.g. "Vânzări B2B" vs "Clienți retail"), and exactly one is
/// marked `isDefault = true`. A pipeline owns an ordered list of Stages,
/// each with a type (OPEN, WON or LOST) and an implicit win probability.
/// Deals belong to exactly one (pipeline, stage) pair at a time.
///
/// On tenant register, the AuthService seeds a default pipeline with
/// four stages (New, Qualified, Negotiation, Won + Lost) so the FE has
/// something to render immediately.
model Pipeline {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isDefault   Boolean   @default(false)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  stages PipelineStage[]
  deals  Deal[]

  @@index([tenantId, order])
  @@index([tenantId, isDefault])
  @@map("pipelines")
}

enum StageType {
  OPEN
  WON
  LOST
}

model PipelineStage {
  id          String    @id @default(cuid())
  tenantId    String
  pipelineId  String
  name        String
  type        StageType @default(OPEN)
  order       Int       @default(0)
  probability Int       @default(0) // 0..100, purely informational
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@index([tenantId, pipelineId, order])
  @@map("pipeline_stages")
}

enum DealStatus {
  OPEN
  WON
  LOST
}

/// A Deal is the unit of work on the Kanban. It is linked to (optionally)
/// a company and/or a contact, and always to a (pipeline, stage) pair.
/// `orderInStage` lets us preserve a manual ordering within a column —
/// new deals are appended (max+1), moves set an explicit value, and the
/// service keeps gaps rather than re-packing (cheaper + fewer write locks).
/// `status` is derived from the stage's type at move time, so the FE can
/// filter "open deals" without joining the stages table.
model Deal {
  id              String     @id @default(cuid())
  tenantId        String
  pipelineId      String
  stageId         String
  companyId       String?
  contactId       String?
  ownerId         String? // which user owns the deal
  title           String
  description     String?
  value           Decimal?   @db.Decimal(14, 2)
  currency        String     @default("RON")
  probability     Int? // override of stage.probability (nullable → inherit)
  expectedCloseAt DateTime?
  status          DealStatus @default(OPEN)
  lostReason      String?
  closedAt        DateTime?
  orderInStage    Int        @default(0)
  createdById     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  pipeline Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage    PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)
  tasks    Task[]

  @@index([tenantId, pipelineId, stageId, orderInStage])
  @@index([tenantId, status])
  @@index([tenantId, ownerId, status])
  @@index([tenantId, companyId])
  @@index([tenantId, contactId])
  @@index([tenantId, expectedCloseAt])
  @@map("deals")
}

enum TaskStatus {
  OPEN
  DONE
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
}

/// A Task can hang off a Deal OR a polymorphic subject (Company/Contact/
/// Client). Exactly one of (dealId) or (subjectType + subjectId) is
/// populated — the service asserts this. Tasks join the polymorphic
/// SubjectType family along with Notes/Attachments/Reminders.
model Task {
  id          String       @id @default(cuid())
  tenantId    String
  dealId      String?
  subjectType SubjectType?
  subjectId   String?
  assigneeId  String? // user who must complete it
  title       String
  description String?
  dueAt       DateTime?
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(NORMAL)
  completedAt DateTime?
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  deal Deal? @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([tenantId, assigneeId, status, dueAt])
  @@index([tenantId, status, dueAt])
  @@index([tenantId, dealId])
  @@index([tenantId, subjectType, subjectId])
  @@map("tasks")
}

/// Sprint 11 — Email integration (send-only MVP).
///
/// EmailAccount stores per-user SMTP credentials. The password is encrypted
/// at rest using AES-256-GCM with a server-side ENCRYPTION_KEY (env var).
/// Each user can have multiple accounts but exactly one marked `isDefault`.
/// The fromEmail is what appears in the From header; smtpUser is the login.
model EmailAccount {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String // the user who owns this account
  label       String // friendly name, e.g. "Gmail profesional"
  smtpHost    String
  smtpPort    Int       @default(587)
  smtpSecure  Boolean   @default(false) // true = implicit TLS (port 465)
  smtpUser    String
  smtpPassEnc String // AES-256-GCM encrypted password (base64)
  fromName    String
  fromEmail   String
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  messages EmailMessage[]

  @@index([tenantId, userId])
  @@index([tenantId, userId, isDefault])
  @@map("email_accounts")
}

enum EmailStatus {
  QUEUED
  SENDING
  SENT
  FAILED
}

/// EmailMessage tracks every email sent from the CRM. Linked to a polymorphic
/// subject (Company/Contact/Client) so sent emails appear on the timeline.
/// Sending is async: the controller creates a QUEUED row + enqueues a BullMQ
/// job; the processor sends via Nodemailer and flips status to SENT or FAILED.
model EmailMessage {
  id           String      @id @default(cuid())
  tenantId     String
  accountId    String
  subjectType  SubjectType
  subjectId    String
  toAddresses  String[] // array of email addresses
  ccAddresses  String[]    @default([])
  bccAddresses String[]    @default([])
  subject      String      @db.VarChar(998)
  /// RFC 5322 soft-limit 998 chars/line; hard-cap HTML at 1 MiB to prevent
  /// oversized row writes and reduce DB replication pressure.
  bodyHtml     String      @db.VarChar(1048576)
  bodyText     String?     @db.VarChar(262144) // plain-text fallback, 256 KiB
  status       EmailStatus @default(QUEUED)
  sentAt       DateTime?
  errorMessage String?
  messageId    String? // SMTP Message-ID header after sending
  createdById  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  account EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tracks  EmailTrack[]

  @@index([tenantId, subjectType, subjectId, createdAt])
  @@index([tenantId, accountId, status])
  @@index([tenantId, createdById, createdAt])
  @@index([tenantId, status])
  @@map("email_messages")
}

enum EmailTrackKind {
  OPEN
  CLICK
}

/// Tracks opens (tracking pixel hit) + clicks (redirect endpoint) for
/// outbound emails. One row per event, not per recipient — we don't have
/// per-recipient IDs because a single message can have multiple recipients
/// and all share the same pixel/link URLs. If you need per-recipient
/// granularity, generate separate EmailMessage rows per recipient.
model EmailTrack {
  id        String         @id @default(cuid())
  tenantId  String         @map("tenant_id")
  messageId String         @map("message_id")
  kind      EmailTrackKind
  url       String? // present for CLICK, null for OPEN
  ipAddress String?        @map("ip_address")
  userAgent String?        @map("user_agent")
  createdAt DateTime       @default(now()) @map("created_at")

  message EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([tenantId, messageId, createdAt])
  @@index([tenantId, kind, createdAt])
  @@map("email_tracks")
}

/// Sprint 12 — Calls (Twilio).
///
/// Phone numbers purchased via Twilio and assigned to users. Each user can
/// have exactly one default number. Outbound calls use the caller's default
/// (or explicit) number as the From. Inbound calls are routed via webhooks
/// based on the To number.
model PhoneNumber {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String? // null = tenant-level, used by everyone
  twilioSid String    @unique
  number    String // E.164: +40712345678
  label     String?
  isDefault Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  calls Call[]

  @@index([tenantId, userId])
  @@index([tenantId, number])
  @@map("phone_numbers")
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  QUEUED // just initiated via API, not yet dialled
  RINGING // Twilio is dialling
  IN_PROGRESS // call answered
  COMPLETED // ended normally
  BUSY
  NO_ANSWER
  FAILED
  CANCELED
}

enum TranscriptionStatus {
  NONE // no recording / not applicable
  PENDING // recording available, waiting for AI worker
  IN_PROGRESS // AI worker is processing
  COMPLETED
  FAILED
}

/// A Call row is the canonical record of a phone call — created either
/// when the user clicks "call" in the CRM (outbound) or when Twilio posts
/// an inbound webhook. Linked polymorphically to a subject (Company /
/// Contact / Client) so calls appear in the timeline.
///
/// The recording lives in MinIO after download (bucket key = storage_key).
/// Transcript + summary are populated by the S13 AI worker asynchronously.
model Call {
  id                  String              @id @default(cuid())
  tenantId            String
  subjectType         SubjectType
  subjectId           String
  phoneNumberId       String? // our side of the call
  userId              String? // which user initiated/received
  twilioCallSid       String?             @unique
  direction           CallDirection
  status              CallStatus          @default(QUEUED)
  fromNumber          String
  toNumber            String
  startedAt           DateTime?
  answeredAt          DateTime?
  endedAt             DateTime?
  durationSec         Int?
  recordingSid        String?
  recordingUrl        String? // Twilio URL (signed, short-lived)
  recordingStorageKey String? // MinIO key after download
  transcriptionStatus TranscriptionStatus @default(NONE)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?

  phoneNumber PhoneNumber?    @relation(fields: [phoneNumberId], references: [id], onDelete: SetNull)
  transcript  CallTranscript?

  @@index([tenantId, subjectType, subjectId, createdAt])
  @@index([tenantId, userId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, transcriptionStatus])
  @@map("calls")
}

/// Sprint 13 — AI worker output. A Call has at most one CallTranscript;
/// populated by the Python ai-worker after transcription + PII redaction
/// + summarisation. Keeping it in a separate table because the payload is
/// large (full transcript JSON with diarization) and we often read Call
/// rows without needing the transcript.
model CallTranscript {
  id           String   @id @default(cuid())
  tenantId     String
  callId       String   @unique
  language     String? // ISO 639-1 detected by Whisper
  rawText      String // full transcript, concatenated
  segments     Json // array of { start, end, speaker, text }
  redactedText String? // text after Presidio PII redaction
  summary      String? // short Claude-generated summary
  actionItems  Json? // array of extracted action items (strings)
  sentiment    String? // positive / neutral / negative
  topics       Json? // array of topics
  processedAt  DateTime @default(now())
  model        String? // which Claude model was used
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([tenantId, callId])
  @@map("call_transcripts")
}

/// Sprint 15 — Automated workflows/sequences.
///
/// A Workflow is a tenant-scoped automation: one trigger event starts an
/// ordered list of WorkflowSteps. A WorkflowRun tracks one execution of a
/// workflow for one subject (Deal / Contact / Company).
enum WorkflowTrigger {
  DEAL_CREATED
  DEAL_STAGE_CHANGED
  CONTACT_CREATED
  COMPANY_CREATED
}

enum WorkflowActionType {
  SEND_EMAIL
  CREATE_TASK
  ADD_NOTE
  WAIT_DAYS
  SEND_CAMPAIGN
}

enum WorkflowRunStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model Workflow {
  id            String          @id @default(cuid())
  tenantId      String          @map("tenant_id")
  name          String
  description   String?
  isActive      Boolean         @default(true) @map("is_active")
  trigger       WorkflowTrigger
  /// { stageId?: string } for DEAL_STAGE_CHANGED, {} for others
  triggerConfig Json            @default("{}") @map("trigger_config")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")

  steps WorkflowStep[]
  runs  WorkflowRun[]

  @@index([tenantId, isActive])
  @@map("workflows")
}

model WorkflowStep {
  id           String             @id @default(cuid())
  workflowId   String             @map("workflow_id")
  tenantId     String             @map("tenant_id")
  order        Int                @default(0)
  actionType   WorkflowActionType @map("action_type")
  /// SEND_EMAIL: { accountId, subject, body }
  /// CREATE_TASK: { title, priority, dueInDays }
  /// ADD_NOTE: { body }
  /// WAIT_DAYS: { days }
  actionConfig Json               @default("{}") @map("action_config")
  createdAt    DateTime           @default(now()) @map("created_at")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, order])
  @@map("workflow_steps")
}

model WorkflowRun {
  id          String            @id @default(cuid())
  tenantId    String            @map("tenant_id")
  workflowId  String            @map("workflow_id")
  subjectType String            @map("subject_type") // 'DEAL' | 'CONTACT' | 'COMPANY'
  subjectId   String            @map("subject_id")
  status      WorkflowRunStatus @default(RUNNING)
  currentStep Int               @default(0) @map("current_step")
  startedAt   DateTime          @default(now()) @map("started_at")
  completedAt DateTime?         @map("completed_at")
  error       String?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([tenantId, workflowId, status])
  @@index([tenantId, subjectType, subjectId])
  @@map("workflow_runs")
}

// ─── S22 Invoices ────────────────────────────────────────────────────────────
// Facturi emise de către tenant către Company (clienți).
// Status transitions: DRAFT → ISSUED → (PARTIALLY_PAID|PAID|OVERDUE|CANCELLED).
// Numbering: (series, number) unique per tenant — standard RO invoice practice.

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum InvoiceCurrency {
  RON
  EUR
  USD
}

model Invoice {
  id            String          @id @default(cuid())
  tenantId      String          @map("tenant_id")
  companyId     String          @map("company_id")
  dealId        String?         @map("deal_id")
  series        String
  number        Int
  issueDate     DateTime        @map("issue_date")
  dueDate       DateTime        @map("due_date")
  subtotal      Decimal         @db.Decimal(14, 2)
  vatAmount     Decimal         @default(0) @map("vat_amount") @db.Decimal(14, 2)
  total         Decimal         @db.Decimal(14, 2)
  currency      InvoiceCurrency @default(RON)
  status        InvoiceStatus   @default(DRAFT)
  notes         String?
  pdfStorageKey String?         @map("pdf_storage_key")
  createdById   String?         @map("created_by_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")

  lines    InvoiceLine[]
  payments Payment[]

  @@unique([tenantId, series, number])
  @@index([tenantId, companyId, issueDate])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@map("invoices")
}

model InvoiceLine {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  invoiceId   String   @map("invoice_id")
  productId   String?  @map("product_id")
  position    Int
  description String   @db.VarChar(500)
  quantity    Decimal  @db.Decimal(14, 3)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(14, 2)
  vatRate     Decimal  @default(19) @map("vat_rate") @db.Decimal(5, 2)
  subtotal    Decimal  @db.Decimal(14, 2)
  vatAmount   Decimal  @map("vat_amount") @db.Decimal(14, 2)
  total       Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@map("invoice_lines")
}

// ─── S24 Payments (scaffold — used by Invoice status calc) ──────────────────

enum PaymentMethod {
  BANK
  CASH
  CARD
  OTHER
}

model Payment {
  id          String        @id @default(cuid())
  tenantId    String        @map("tenant_id")
  invoiceId   String        @map("invoice_id")
  amount      Decimal       @db.Decimal(14, 2)
  paidAt      DateTime      @map("paid_at")
  method      PaymentMethod @default(BANK)
  reference   String?
  notes       String?
  createdById String?       @map("created_by_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  deletedAt   DateTime?     @map("deleted_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, invoiceId])
  @@index([tenantId, paidAt])
  @@map("payments")
}

// ─── S23 Projects ────────────────────────────────────────────────────────────
// A Project is created from a won Deal — groups invoices, tasks, attachments
// under one delivery umbrella.

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

model Project {
  id          String          @id @default(cuid())
  tenantId    String          @map("tenant_id")
  companyId   String          @map("company_id")
  dealId      String?         @unique @map("deal_id")
  name        String
  description String?
  status      ProjectStatus   @default(PLANNED)
  startDate   DateTime?       @map("start_date")
  endDate     DateTime?       @map("end_date")
  budget      Decimal?        @db.Decimal(14, 2)
  currency    InvoiceCurrency @default(RON)
  createdById String?         @map("created_by_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")

  @@index([tenantId, companyId])
  @@index([tenantId, status])
  @@map("projects")
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  tenantId         String
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("sessions")
}

// ─── Quotes (oferte comerciale) ──────────────────────────────────────────────
// Separate from Invoices: Quote → (accepted) → Invoice conversion.
// Status flow: DRAFT → SENT → ACCEPTED | REJECTED | EXPIRED.

enum QuoteStatus {
  DRAFT
  PENDING_APPROVAL
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quote {
  id          String          @id @default(cuid())
  tenantId    String          @map("tenant_id")
  companyId   String          @map("company_id")
  dealId      String?         @map("deal_id")
  /// Human-readable number e.g. "OF-2024-001"
  number      String
  title       String
  issueDate   DateTime        @map("issue_date")
  validUntil  DateTime        @map("valid_until")
  subtotal    Decimal         @db.Decimal(14, 2)
  vatAmount   Decimal         @default(0) @map("vat_amount") @db.Decimal(14, 2)
  total       Decimal         @db.Decimal(14, 2)
  currency    InvoiceCurrency @default(RON)
  status      QuoteStatus     @default(DRAFT)
  notes       String?
  /// Set when the quote is converted to an invoice
  invoiceId   String?         @unique @map("invoice_id")
  createdById String?         @map("created_by_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")

  company Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  lines   QuoteLine[]

  @@unique([tenantId, number])
  @@index([tenantId, companyId, issueDate])
  @@index([tenantId, status])
  @@map("quotes")
}

model QuoteLine {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  quoteId     String   @map("quote_id")
  productId   String?  @map("product_id")
  position    Int
  description String   @db.VarChar(500)
  quantity    Decimal  @db.Decimal(14, 3)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(14, 2)
  vatRate     Decimal  @default(19) @map("vat_rate") @db.Decimal(5, 2)
  subtotal    Decimal  @db.Decimal(14, 2)
  vatAmount   Decimal  @map("vat_amount") @db.Decimal(14, 2)
  total       Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@map("quote_lines")
}

// ─── Email sequences (S32) ───────────────────────────────────────────────────
// Drip campaigns: a sequence of emails sent with configurable delays.

enum SequenceStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  UNSUBSCRIBED
  FAILED
}

model EmailSequence {
  id          String         @id @default(cuid())
  tenantId    String         @map("tenant_id")
  name        String
  description String?
  status      SequenceStatus @default(DRAFT)
  createdById String?        @map("created_by_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")

  steps       EmailSequenceStep[]
  enrollments SequenceEnrollment[]

  @@index([tenantId, status])
  @@map("email_sequences")
}

model EmailSequenceStep {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  sequenceId String   @map("sequence_id")
  order      Int
  delayDays  Int      @default(0) @map("delay_days")
  subject    String
  bodyHtml   String   @map("body_html")
  bodyText   String?  @map("body_text")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  sequence EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId, order])
  @@map("email_sequence_steps")
}

model SequenceEnrollment {
  id          String           @id @default(cuid())
  tenantId    String           @map("tenant_id")
  sequenceId  String           @map("sequence_id")
  /// Contact email address
  toEmail     String           @map("to_email")
  contactId   String?          @map("contact_id")
  currentStep Int              @default(0) @map("current_step")
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now()) @map("enrolled_at")
  completedAt DateTime?        @map("completed_at")
  nextSendAt  DateTime?        @map("next_send_at")

  sequence EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([tenantId, sequenceId, status])
  @@index([tenantId, status, nextSendAt])
  @@map("sequence_enrollments")
}

// ─── Contact segments (S33) ──────────────────────────────────────────────────
// Saved filter sets for contact list segmentation.

model ContactSegment {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  /// JSON filter tree: { op: 'AND'|'OR', rules: FilterRule[] }
  filterJson  Json     @map("filter_json")
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("contact_segments")
}

// ─── S39 Product Catalog + Price Lists ───────────────────────────────────────

model ProductCategory {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  products Product[]

  @@index([tenantId])
  @@map("product_categories")
}

model Product {
  id           String          @id @default(cuid())
  tenantId     String          @map("tenant_id")
  categoryId   String?         @map("category_id")
  name         String
  sku          String?
  description  String?
  unit         String          @default("buc")
  defaultPrice Decimal         @default(0) @map("default_price") @db.Decimal(14, 2)
  vatRate      Decimal         @default(19) @map("vat_rate") @db.Decimal(5, 2)
  currency     InvoiceCurrency @default(RON)
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")

  category       ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  priceListItems PriceListItem[]
  quoteLines     QuoteLine[]
  invoiceLines   InvoiceLine[]

  @@index([tenantId, isActive])
  @@index([tenantId, categoryId])
  @@index([tenantId, sku])
  @@map("products")
}

model PriceList {
  id          String          @id @default(cuid())
  tenantId    String          @map("tenant_id")
  name        String
  description String?
  currency    InvoiceCurrency @default(RON)
  isDefault   Boolean         @default(false) @map("is_default")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")

  items PriceListItem[]

  @@index([tenantId, isDefault])
  @@map("price_lists")
}

model PriceListItem {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  priceListId String   @map("price_list_id")
  productId   String   @map("product_id")
  unitPrice   Decimal  @map("unit_price") @db.Decimal(14, 2)
  minQuantity Decimal  @default(1) @map("min_quantity") @db.Decimal(14, 3)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId, minQuantity])
  @@index([tenantId, priceListId])
  @@map("price_list_items")
}

// ─── S36 Custom Fields ────────────────────────────────────────────────────────

enum CustomFieldEntityType {
  COMPANY
  CONTACT
  CLIENT
  DEAL
  QUOTE
  INVOICE
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTI_SELECT
}

model CustomFieldDef {
  id         String                @id @default(cuid())
  tenantId   String                @map("tenant_id")
  entityType CustomFieldEntityType @map("entity_type")
  fieldType  CustomFieldType       @map("field_type")
  // internal key (snake_case, immutable after create)
  name       String
  label      String
  // string[] for SELECT/MULTI_SELECT
  options    Json?
  isRequired Boolean               @default(false) @map("is_required")
  order      Int                   @default(0)
  isActive   Boolean               @default(true) @map("is_active")
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")
  deletedAt  DateTime?             @map("deleted_at")

  values CustomFieldValue[]

  @@unique([tenantId, entityType, name])
  @@index([tenantId, entityType, isActive])
  @@map("custom_field_defs")
}

// entityId is a plain string ref — no FK because the entity can be any type.
// Interpret value based on fieldDef.fieldType.
model CustomFieldValue {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  fieldDefId String   @map("field_def_id")
  entityId   String   @map("entity_id")
  value      String
  updatedAt  DateTime @updatedAt @map("updated_at")

  fieldDef CustomFieldDef @relation(fields: [fieldDefId], references: [id], onDelete: Cascade)

  @@unique([fieldDefId, entityId])
  @@index([tenantId, entityId])
  @@map("custom_field_values")
}

// ─── S37 Approval Workflows ───────────────────────────────────────────────────

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalPolicyTrigger {
  QUOTE_ABOVE_VALUE
  DISCOUNT_ABOVE_PCT
}

// Defines when approval is required. Multiple policies can be active per tenant.
model ApprovalPolicy {
  id         String                @id @default(cuid())
  tenantId   String                @map("tenant_id")
  name       String
  trigger    ApprovalPolicyTrigger
  // QUOTE_ABOVE_VALUE: { threshold: number, currency: string }
  // DISCOUNT_ABOVE_PCT: { pct: number }
  config     Json                  @default("{}")
  // null = any manager can approve; else specific user
  approverId String?               @map("approver_id")
  isActive   Boolean               @default(true) @map("is_active")
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")
  deletedAt  DateTime?             @map("deleted_at")

  requests ApprovalRequest[]

  @@index([tenantId, isActive])
  @@map("approval_policies")
}

model ApprovalRequest {
  id          String         @id @default(cuid())
  tenantId    String         @map("tenant_id")
  policyId    String         @map("policy_id")
  // Only quotes for now; extend via subjectType later
  quoteId     String         @map("quote_id")
  requestedBy String         @map("requested_by")
  status      ApprovalStatus @default(PENDING)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  policy    ApprovalPolicy     @relation(fields: [policyId], references: [id], onDelete: Cascade)
  decisions ApprovalDecision[]

  @@index([tenantId, quoteId])
  @@index([tenantId, status])
  @@map("approval_requests")
}

model ApprovalDecision {
  id        String         @id @default(cuid())
  tenantId  String         @map("tenant_id")
  requestId String         @map("request_id")
  deciderId String         @map("decider_id")
  status    ApprovalStatus
  comment   String?
  decidedAt DateTime       @default(now()) @map("decided_at")

  request ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([tenantId, requestId])
  @@map("approval_decisions")
}

// ─── S40 SSO / SAML ──────────────────────────────────────────────────────────

model SsoConfig {
  id             String   @id @default(cuid())
  tenantId       String   @unique @map("tenant_id")
  // IdP metadata — paste the SSO URL + public cert from your IdP dashboard
  idpSsoUrl      String   @map("idp_sso_url")
  idpCertificate String   @map("idp_certificate")
  // SP entity ID — usually https://your-domain/api/v1/sso/:tenantSlug/metadata
  spEntityId     String   @map("sp_entity_id")
  // Optional: sign AuthnRequests with SP private key
  spPrivateKey   String?  @map("sp_private_key")
  // SAML attribute names that map to our user fields
  attrEmail      String   @default("email") @map("attr_email")
  attrFirstName  String   @default("firstName") @map("attr_first_name")
  attrLastName   String   @default("lastName") @map("attr_last_name")
  // Optional attribute that maps to UserRole enum value
  attrRole       String?  @map("attr_role")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("sso_configs")
}

// ─── S41 WhatsApp Business ────────────────────────────────────────────────────

enum WhatsappMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsappMessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model WhatsappAccount {
  id                 String    @id @default(cuid())
  tenantId           String    @map("tenant_id")
  phoneNumberId      String    @map("phone_number_id")
  displayPhoneNumber String    @map("display_phone_number")
  accessTokenEnc     String    @map("access_token_enc")
  webhookVerifyToken String    @map("webhook_verify_token")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  messages WhatsappMessage[]

  @@index([tenantId, isActive])
  @@map("whatsapp_accounts")
}

model WhatsappMessage {
  id          String                   @id @default(cuid())
  tenantId    String                   @map("tenant_id")
  accountId   String                   @map("account_id")
  subjectType SubjectType
  subjectId   String                   @map("subject_id")
  direction   WhatsappMessageDirection
  status      WhatsappMessageStatus    @default(SENT)
  fromNumber  String                   @map("from_number")
  toNumber    String                   @map("to_number")
  body        String?
  mediaUrl    String?                  @map("media_url")
  mediaType   String?                  @map("media_type")
  externalId  String?                  @unique @map("external_id")
  sentAt      DateTime?                @map("sent_at")
  deliveredAt DateTime?                @map("delivered_at")
  readAt      DateTime?                @map("read_at")
  createdAt   DateTime                 @default(now()) @map("created_at")

  account WhatsappAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([tenantId, subjectType, subjectId, createdAt])
  @@index([tenantId, accountId])
  @@map("whatsapp_messages")
}

// ─── S42 ANAF e-Factura ───────────────────────────────────────────────────────

enum AnafSubmissionStatus {
  PENDING
  UPLOADED
  IN_VALIDATION
  OK
  NOK
  FAILED
}

model AnafSubmission {
  id           String               @id @default(cuid())
  tenantId     String               @map("tenant_id")
  invoiceId    String               @unique @map("invoice_id")
  status       AnafSubmissionStatus @default(PENDING)
  uploadIndex  String?              @map("upload_index")
  downloadId   String?              @map("download_id")
  errorMessage String?              @map("error_message")
  xmlContent   String?              @map("xml_content")
  submittedAt  DateTime?            @map("submitted_at")
  validatedAt  DateTime?            @map("validated_at")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  @@index([tenantId, status])
  @@index([tenantId, invoiceId])
  @@map("anaf_submissions")
}

// ─── S43 Calendar Sync ────────────────────────────────────────────────────────

enum CalendarProvider {
  GOOGLE
  OUTLOOK
}

model CalendarIntegration {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  userId          String           @map("user_id")
  provider        CalendarProvider
  accessTokenEnc  String           @map("access_token_enc")
  refreshTokenEnc String?          @map("refresh_token_enc")
  tokenExpiresAt  DateTime?        @map("token_expires_at")
  calendarId      String?          @map("calendar_id")
  isActive        Boolean          @default(true) @map("is_active")
  lastSyncAt      DateTime?        @map("last_sync_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  events CalendarEvent[]

  @@unique([tenantId, userId, provider])
  @@index([tenantId, userId])
  @@map("calendar_integrations")
}

model CalendarEvent {
  id            String       @id @default(cuid())
  tenantId      String       @map("tenant_id")
  integrationId String       @map("integration_id")
  externalId    String       @map("external_id")
  title         String
  description   String?
  startAt       DateTime     @map("start_at")
  endAt         DateTime     @map("end_at")
  location      String?
  attendees     Json?
  subjectType   SubjectType?
  subjectId     String?      @map("subject_id")
