// ─── S46 Client Portal ────────────────────────────────────────────────────────

model PortalToken {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  // M-aud-H7: raw token only ever lives in the email link sent to the
  // client. DB stores SHA-256(token) so a DB breach (backup leak, SQL
  // injection elsewhere, insider) does NOT yield usable tokens — the
  // attacker would need to also control the message delivering the raw
  // token. Same posture as Session.refreshTokenHash.
  tokenHash String    @unique @map("token_hash")
  email     String
  companyId String?   @map("company_id")
  clientId  String?   @map("client_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([tenantId, email])
  @@index([tokenHash])
  @@map("portal_tokens")
}

