// AMASS-CRM v2 — Prisma schema
// Sprint 1: Tenant, User, Session (auth foundation)
// RLS policies + audit + RBAC arrive in Sprint 2.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
  VIEWER
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  fullName     String
  role         UserRole @default(AGENT)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions Session[]

  // Email is unique within a tenant, not globally — multi-tenant requirement.
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

enum ImportType {
  CLIENTS
  COMPANIES
  CONTACTS
}

enum ImportStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model ImportJob {
  id           String       @id @default(cuid())
  tenantId     String
  type         ImportType
  status       ImportStatus @default(PENDING)
  fileName     String
  storageKey   String       // MinIO object key — `<tenantId>/imports/<uuid>-<fileName>`
  totalRows    Int          @default(0)
  processed    Int          @default(0)
  succeeded    Int          @default(0)
  failed       Int          @default(0)
  skipped      Int          @default(0)
  errors       Json?        // array of {row, message}
  createdById  String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@map("import_jobs")
}

enum CompanySize {
  MICRO   // 1-9
  SMALL   // 10-49
  MEDIUM  // 50-249
  LARGE   // 250+
}

model Company {
  id          String       @id @default(cuid())
  tenantId    String
  name        String
  vatNumber   String?      // CUI for Romanian companies
  registrationNumber String? // J-number
  industry    String?
  size        CompanySize?
  website     String?
  email       String?
  phone       String?
  addressLine String?
  city        String?
  county      String?
  postalCode  String?
  country     String?      @default("RO")
  notes       String?
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  contacts Contact[]

  @@index([tenantId, createdAt])
  @@index([tenantId, name])
  @@index([tenantId, vatNumber])
  @@map("companies")
}

model Contact {
  id          String    @id @default(cuid())
  tenantId    String
  companyId   String?
  firstName   String
  lastName    String
  jobTitle    String?
  email       String?
  phone       String?
  mobile      String?
  notes       String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, companyId])
  @@index([tenantId, lastName, firstName])
  @@map("contacts")
}

model Client {
  id          String    @id @default(cuid())
  tenantId    String
  firstName   String
  lastName    String
  email       String?
  phone       String?
  mobile      String?
  addressLine String?
  city        String?
  county      String?
  postalCode  String?
  country     String?   @default("RO")
  notes       String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([tenantId, createdAt])
  @@index([tenantId, lastName, firstName])
  @@index([tenantId, email])
  @@map("clients")
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorId     String?
  action      String   // e.g. "user.create", "auth.login", "company.delete"
  subjectType String?  // e.g. "user", "company"
  subjectId   String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@index([tenantId, subjectType, subjectId])
  @@map("audit_logs")
}

/// Polymorphic subject types — every notes/activities/attachments row
/// references one of these via (subjectType, subjectId). Keep in sync with
/// SubjectTypeSchema in @amass/shared.
enum SubjectType {
  COMPANY
  CONTACT
  CLIENT
}

model Attachment {
  id           String      @id @default(cuid())
  tenantId     String
  subjectType  SubjectType
  subjectId    String
  storageKey   String      @unique // path inside the MinIO bucket
  fileName     String
  mimeType     String
  size         Int
  uploadedById String?
  createdAt    DateTime    @default(now())
  deletedAt    DateTime?

  @@index([tenantId, subjectType, subjectId, createdAt])
  @@index([tenantId, createdAt])
  @@map("attachments")
}

model Note {
  id          String      @id @default(cuid())
  tenantId    String
  subjectType SubjectType
  subjectId   String
  body        String
  authorId    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  @@index([tenantId, subjectType, subjectId, createdAt])
  @@index([tenantId, createdAt])
  @@map("notes")
}

/// Polymorphic reminder. Created by a user, attached to any subject
/// (Company / Contact / Client today). A BullMQ delayed job is enqueued
/// at create time with `jobId = reminder.id` for idempotency. When the
/// delayed job fires, the processor flips status to FIRED and writes an
/// activity row. Snooze = cancel old job + re-enqueue at the new time;
/// dismiss/delete = cancel job. The job and the row are kept in sync via
/// the row id == BullMQ jobId convention.
enum ReminderStatus {
  PENDING
  FIRED
  DISMISSED
  CANCELLED
}

model Reminder {
  id          String         @id @default(cuid())
  tenantId    String
  subjectType SubjectType
  subjectId   String
  actorId     String?        // who created the reminder (null if system)
  title       String
  body        String?
  remindAt    DateTime
  status      ReminderStatus @default(PENDING)
  firedAt     DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  @@index([tenantId, subjectType, subjectId, remindAt])
  @@index([tenantId, actorId, status, remindAt])
  @@index([tenantId, status, remindAt])
  @@map("reminders")
}

/// Domain-level activity log (NOT the audit_logs table). Activities are
/// what shows up in the UI timeline: "Andrei created this company",
/// "Maria added a note", "Status changed to WON". Audit_logs are
/// security-level and stay separate.
model Activity {
  id          String      @id @default(cuid())
  tenantId    String
  subjectType SubjectType
  subjectId   String
  actorId     String?
  action      String      // e.g. "company.created", "note.added", "company.updated"
  metadata    Json?
  createdAt   DateTime    @default(now())

  @@index([tenantId, subjectType, subjectId, createdAt])
  @@index([tenantId, createdAt])
  @@map("activities")
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  tenantId         String
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("sessions")
}
